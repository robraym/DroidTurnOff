<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="AppTheme" parent="@android:style/Theme.Material">
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowActionBar">false</item>
        <item name="android:windowBackground">@color/oneUiBackground</item>
        <item name="android:windowContentOverlay">@null</item>
        <item name="android:fontFamily">sans</item>
        <item name="android:colorAccent">@color/colorAccent</item>
        <item name="android:colorControlActivated">@color/colorAccent</item>
        <item name="android:colorControlHighlight">@color/colorAccent</item>
        <item name="android:colorButtonNormal">@color/oneUiControlNormal</item>
        <item name="android:statusBarColor">@color/oneUiBackground</item>
        <item name="android:navigationBarColor">@color/oneUiBackground</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:windowLightNavigationBar">false</item>
    </style>
</resources>
